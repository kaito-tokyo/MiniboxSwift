set -eu

usage() {
	printf 'Usage: minibox <subcommand> [args...]\n'
	printf 'Available subcommands:\n'
	printf '  create-base  Creates a base image.\n'
	printf '  prepare      Prepares a base image for automation.\n'
	printf '  run          Runs a runner.\n'
	printf '  view         Starts a new VM with a image bundle to view its contents.\n'
	printf '  ls           Lists images on disk.\n'
}

if [ "$#" -eq 0 ]; then
	usage >&2
	exit 64
fi

case "$1" in
create-base | prepare | run | view | ls)
	subcommand="minibox-$1"
	shift
	;;
*)
	printf 'Unknown subcommand: %s\n' "$1" >&2
	usage >&2
	exit 64
	;;
esac

if [ -n "${MINIBOX_PATH-}" ]; then
	PATH="${MINIBOX_PATH}:${PATH}"
fi

if ! command -v "${subcommand}" >/dev/null 2>&1; then
	printf 'Subcommand not found: %s\n' "${subcommand}" >&2
	exit 127
fi

exec "${subcommand}" "$@"
